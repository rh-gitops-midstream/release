{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "baseBranchPatterns": [
    "main",
    "release-1.21",
    "release-1.20",
    "release-1.19",
  ],
  "ignoreDeps": [
    "registry.redhat.io/rhel9/go-toolset",
    "registry.redhat.io/rhel8/go-toolset",
    "registry.redhat.io/openshift-gitops-1/argocd-agent-rhel8",
    "registry.redhat.io/openshift-gitops-1/argocd-agent-rhel9"
  ],
  "packageRules": [
    {
      "matchManagers": [
        "git-submodules"
      ],
      "enabled": false
    }
  ]
}
